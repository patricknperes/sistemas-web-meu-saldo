{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite",
            "buildCommand": "npm run build",
            "outputDirectory": "dist"
        },
        "backend": {
            "root": "backend",
            "framework": "express",
            "entrypoint": "src/server.js"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": {
                "service": "backend"
            }
        },
        {
            "source": "/(.*)",
            "destination": {
                "service": "frontend"
            }
        }
    ]
}